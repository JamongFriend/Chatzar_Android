<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="#FFF9F9">

    <ImageView
        android:id="@+id/iv_requester_profile"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@mipmap/ic_launcher_round"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

    <TextView
        android:id="@+id/tv_requester_nickname"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="신청자 닉네임"
        android:textColor="@color/black"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/iv_requester_profile"
        app:layout_constraintTop_toTopOf="@id/iv_requester_profile" />

    <TextView
        android:id="@+id/tv_requester_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="25세 | 친구 신청"
        android:textColor="#FF3B30"
        android:textSize="13sp"
        android:layout_marginTop="2dp"
        app:layout_constraintStart_toStartOf="@id/tv_requester_nickname"
        app:layout_constraintTop_toBottomOf="@id/tv_requester_nickname" />

    <Button
        android:id="@+id/btn_accept_friend"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="수락"
        android:textSize="12sp"
        android:paddingHorizontal="12dp"
        android:backgroundTint="#007AFF"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
