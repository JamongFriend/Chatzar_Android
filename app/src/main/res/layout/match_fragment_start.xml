<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="@color/white">

    <TextView
        android:id="@+id/tv_match_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="새로운 인연 찾기"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/tv_match_desc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="원하는 대화 상대의 조건을 확인하고 매칭을 시작하세요."
        android:textColor="#666666"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tv_match_title"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp" />

    <!-- 현재 설정된 조건 카드 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_current_preference"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/tv_match_desc">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="나의 매칭 조건"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/black" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginVertical="12dp" />

            <TextView
                android:id="@+id/tv_pref_summary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="설정된 조건이 없습니다.\n조건을 추가하여 더 잘 맞는 상대를 찾아보세요."
                android:textColor="#444444"
                android:lineSpacingExtra="4dp" />

            <Button
                android:id="@+id/btn_edit_preference"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="조건 수정하기"
                android:layout_gravity="end"
                android:layout_marginTop="8dp" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 매칭 시작 버튼 -->
    <Button
        android:id="@+id/btn_start_matching"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="매칭 시작하기"
        android:backgroundTint="#007AFF"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
