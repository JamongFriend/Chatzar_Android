<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="뒤로가기"
            android:src="@drawable/ic_arrow_back"
            android:padding="0dp"  android:scaleType="centerInside" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tv_member_edit_title"
            app:layout_constraintBottom_toBottomOf="@id/tv_member_edit_title"
            android:layout_marginStart="-12dp" app:tint="@android:color/black" />

        <TextView
            android:id="@+id/tv_member_edit_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="내 정보 수정"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="parent" />

        <FrameLayout
            android:id="@+id/layout_member_image_edit"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/tv_member_edit_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/iv_member_edit_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@mipmap/ic_launcher_round" />

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="bottom|end"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="#007AFF"
                android:background="@drawable/bg_search_input"
                android:padding="4dp" />
        </FrameLayout>

        <TextView
            android:id="@+id/label_member_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="이름"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/layout_member_image_edit"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/et_member_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="실명을 입력하세요"
            android:inputType="textPersonName"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/label_member_name" />

        <TextView
            android:id="@+id/label_member_nickname"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="닉네임"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/et_member_name"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/et_member_new_nickname"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="변경할 닉네임"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/label_member_nickname"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn_member_nickname_check"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_member_nickname_check"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="중복확인"
            app:layout_constraintBottom_toBottomOf="@id/et_member_new_nickname"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/et_member_new_nickname" />

        <TextView
            android:id="@+id/label_member_age"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="나이"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/et_member_new_nickname"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/et_member_age"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="나이를 입력하세요"
            android:inputType="number"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/label_member_age" />

        <Button
            android:id="@+id/btn_member_save"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="변경하기"
            android:backgroundTint="#007AFF"
            android:layout_marginTop="40dp"
            app:layout_constraintTop_toBottomOf="@id/et_member_age"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="16dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>